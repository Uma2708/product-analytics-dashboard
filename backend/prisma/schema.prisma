datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Use plain string for gender in SQLite local dev

model User {
  id        Int            @id @default(autoincrement())
  username  String         @unique
  password  String
  age       Int
  gender    String
  clicks    FeatureClick[]
  createdAt DateTime       @default(now())
}

model FeatureClick {
  id          Int      @id @default(autoincrement())
  userId      Int
  featureName String
  timestamp   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([featureName])
  @@index([timestamp])
}
